# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
# For local development without Docker, use 'localhost'
# For Docker, use 'mysql' (the service name from docker-compose.yml)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=product_submission_db
DATABASE_USER=appuser
DATABASE_PASSWORD=apppassword

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# CORS Configuration
# Frontend URL for CORS policy
FRONTEND_URL=http://localhost:3000

# MySQL Root Password (for docker-compose)
MYSQL_ROOT_PASSWORD=rootpassword
